# PropStream API Configuration
PROPSTREAM_API_KEY=your_propstream_api_key_here

# Pipedrive API Configuration
PIPEDRIVE_API_TOKEN=your_pipedrive_api_token_here

# Database Configuration
DATABASE_URL=sqlite://propstream_pipedrive.db

# Scheduler Configuration (Cron format: sec min hour day month weekday)
# Examples:
# "0 0 9 * * *"     = Daily at 9:00 AM
# "0 0 */6 * * *"   = Every 6 hours
# "0 0 9 * * MON"   = Every Monday at 9:00 AM
SCHEDULER_CRON=0 0 9 * * *

# Logging Level (trace, debug, info, warn, error)
RUST_LOG=info
